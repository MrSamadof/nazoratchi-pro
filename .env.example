# ============================================
# Nazoratchi Pro — Environment variables
# ============================================
# Bu faylni `.env` deb nusxa oling va to'ldiring.
# `.env` GitHub ga yuborilmasin (`.gitignore` da bor).

# --- Database ---
MONGO_URI=mongodb://localhost:27017/nazoratchi
MONGO_DB_NAME=nazoratchi

# Docker uchun MongoDB credential (faqat docker-compose ishlatadi)
MONGO_INITDB_ROOT_USERNAME=nazoratchi
MONGO_INITDB_ROOT_PASSWORD=nazoratchi_dev_password

# --- Session (Web auth) ---
# Cookie sirini imzolash uchun uzun random satr (kamida 32 belgi)
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars
SESSION_COOKIE_NAME=nz_session
SESSION_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
# Cookie `Secure` flagi: TLS bilan (HTTPS) ishlaganda "true", TLS'siz (HTTP) deploy uchun "false".
# Bo'sh qoldirilsa NODE_ENV bo'yicha aniqlanadi (production => true). HTTP'da "false" shart!
COOKIE_SECURE=

# --- Birinchi CEO (seed yaratadi — DB tozalanib, faqat shu user qoladi) ---
# Telefon — login uchun, PIN — 4-6 raqam. Telegram ID ixtiyoriy.
CEO_PHONE=998901234567
CEO_PASSWORD=1234
CEO_FIRST_NAME=Super
CEO_LAST_NAME=Admin
CEO_TELEGRAM_ID=

# --- Telegram (ixtiyoriy — notif yuborish + akkaunt bog'lash uchun) ---
# Bo'sh qoldirilsa Telegram xabarlar yuborilmaydi va bog'lash o'chiq (silent no-op).
BOT_TOKEN=
# Bot username (@'siz, masalan "NazoratchiBot"). Bog'lash deep-link'i uchun.
# Bo'sh qoldirilsa getMe() orqali avtomatik aniqlanadi.
BOT_USERNAME=

# --- Integratsiya kalitlari shifrlash (MAJBURIY, kamida 16 belgi) ---
# Gemini/Telegram kalitlari DB da shu kalit bilan shifrlanadi.
# Yangi kalit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Diqqat: o'zgartirilsa DB dagi shifrlangan kalitlar o'qib bo'lmaydigan bo'ladi.
SETTINGS_ENCRYPTION_KEY=

# --- AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Billz POS API (do'kon UUID lari DB dagi Store hujjatlarida saqlanadi) ---
BILLZ_API_URL=https://api-admin.billz.ai/v1
BILLZ_API_TOKEN=

# --- Logger ---
LOG_LEVEL=debug
NODE_ENV=development

# --- Vaqt zonasi ---
TZ=Asia/Tashkent
